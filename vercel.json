{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://your-backend.railway.app/api/$1",
      "headers": {
        "x-forwarded-proto": "https"
      }
    },
    {
      "src": "/(.*)",
      "dest": "frontend/$1"
    }
  ],
  "env": {
    "NEXT_PUBLIC_API_URL": "@backend-url"
  },
  "build": {
    "env": {
      "NEXT_PUBLIC_API_URL": "@backend-url"
    }
  }
}
